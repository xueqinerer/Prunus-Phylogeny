cat("BD: Constant birth-death")#
cst_BD<-bd_ML(branch.times, initparsopt = c(0.2,0.01), missnumspec=missing.lineages[i], tdmodel=0, cond=1, btorph=1, soc=2, maxiter=50000)#
print(cst_BD)
cat("DDX+E: Exponential dependence of speciation rate with extinction")#
DDD_3<-dd_ML(branch.times, ddmodel=2, initparsopt=c(0.3,0.1,total.diversity), res=resi, missnumspec=missing.lineages[i], cond=1, btorph=1, soc=2, maxiter=50000)#
