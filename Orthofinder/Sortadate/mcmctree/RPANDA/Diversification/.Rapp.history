## Temperatures#
Temperature<-read.table("Temperature.txt",header=T)#
par(mfrow=c(1,1))#
age=(0:(80-1))* -1#
#
colors<-c("floralwhite","blue")#
#
plot(age,age,type = 'n', ylim = c(0, 4500), xlim = c(-80,0), axes=F, ylab = 'Global temperatures', xlab = 'Time (Myrs ago)',main='', bty='n', las=1)#
rect(-100.5,-0.001,-105, 5000, col="white", border=NA)#
rect(-66,-0.001,-100.5, 5000, col="whitesmoke", border=NA)#
rect(-56,-0.001,-66, 5000, col="white", border=NA)#
rect(-56,-0.001,-33.9, 5000, col="whitesmoke", border=NA)#
rect(-33.9,-0.001,-23.03, 5000, col="white", border=NA)#
rect(-23.03,-0.001,-5.33, 5000, col="whitesmoke", border=NA)#
rect(-5.33,-0.001,-2.58, 5000, col="white", border=NA)#
rect(-2.58,-0.001,0, 5000, col="whitesmoke", border=NA)#
#
abline(v=c(-2.58, -5.33, -23.03, -33.9, -56, -100.5),col="black",lty="dotted",lwd="1")#
abline(v=c(-66),col="red",lty="dashed",lwd="2")#
#
axis(side=1, seq(-90, 0, by=10), col="black",col.axis="black",las=1)#
axis(side=2, seq(0, 5000, by=500), col="black",col.axis="black",las=2)#
#
points(-Temperature[,"Age"], Temperature[,"Altitude"], pch=19, lwd=0.5, col=alpha(colors[1], 0.3))#
temp.spl<-smooth.spline(-Temperature[,"Age"], Temperature[,"Altitude"], df=80)#
lines(temp.spl, col=alpha(colors[2], 0.7), lwd=5)#
add_geochrono(0, -0.1)
