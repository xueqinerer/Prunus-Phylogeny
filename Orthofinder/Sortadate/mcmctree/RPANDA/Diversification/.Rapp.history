#Andes<-read.table("../Elevation data/Andes_mean_elevations_no_basins_1.txt", h=T)#
Andes<-read.table("../Elevation data/Andes_mean_elevations_no_basins_2.txt", h=T)#
par(mfrow=c(1,1))#
colors<-c("grey","brown")#
#
## Diversification dynamics#
age=(0:(80-1))* -1#
plot(age,age,type = 'n', ylim = c(0, 4500), xlim = c(-80,0), axes=F, ylab = 'Andean elevation (m)', xlab = 'Time (Myrs ago)',main='', bty='n', las=1)#
rect(-100.5,-0.001,-105, 5000, col="white", border=NA)#
rect(-66,-0.001,-100.5, 5000, col="whitesmoke", border=NA)#
rect(-56,-0.001,-66, 5000, col="white", border=NA)#
rect(-56,-0.001,-33.9, 5000, col="whitesmoke", border=NA)#
rect(-33.9,-0.001,-23.03, 5000, col="white", border=NA)#
rect(-23.03,-0.001,-5.33, 5000, col="whitesmoke", border=NA)#
rect(-5.33,-0.001,-2.58, 5000, col="white", border=NA)#
rect(-2.58,-0.001,0, 5000, col="whitesmoke", border=NA)#
#
abline(v=c(-2.58, -5.33, -23.03, -33.9, -56, -100.5),col="black",lty="dotted",lwd="1")#
abline(v=c(-66),col="red",lty="dashed",lwd="2")#
#
axis(side=1, seq(-90, 0, by=10), col="black",col.axis="black",las=1)#
axis(side=2, seq(0, 5000, by=500), col="black",col.axis="black",las=2)#
#
points(-Andes[,"Age"], Andes[,"Altitude"], pch=19, lwd=0.5, col=alpha(colors[1], 0.3))#
temp.spl<-smooth.spline(-Andes[,"Age"], Andes[,"Altitude"], df=80)#
lines(temp.spl, col=alpha(colors[2], 0.7), lwd=5)#
#
add_geochrono <- function(Y1,Y2){	#
	polygon(-c(145,145,100.5,100.5),     c(Y1,Y2,Y2,Y1), col = "#A0C96D", lwd = 0.5) # Lower Cretaceous#
	polygon(-c(100.5,100.5,66,66),       c(Y1,Y2,Y2,Y1), col = "#BAD25F", lwd = 0.5) # Upper Cretaceous#
	polygon(-c(66,66,56,56),             c(Y1,Y2,Y2,Y1), col = "#F8B77D", lwd = 0.5) # Paleocene#
	polygon(-c(56,56,33.9,33.9),         c(Y1,Y2,Y2,Y1), col = "#FAC18A", lwd = 0.5) # Eocene#
	polygon(-c(33.9,33.9,23.03,23.03),   c(Y1,Y2,Y2,Y1), col = "#FBCC98", lwd = 0.5) # Oligocene#
	polygon(-c(23.03,23.03,5.33,5.33),   c(Y1,Y2,Y2,Y1), col = "#FFED00", lwd = 0.5) # Miocene#
	polygon(-c(5.33,5.33,2.58,2.58),     c(Y1,Y2,Y2,Y1), col = "#FFF7B2", lwd = 0.5) # Pliocene#
	polygon(-c(2.58,2.58,0.0117,0.0117), c(Y1,Y2,Y2,Y1), col = "#FFF1C4", lwd = 0.5) # Pleistocene#
	polygon(-c(0.0117,0.0117,0,0),       c(Y1,Y2,Y2,Y1), col = "#FEF6F2", lwd = 0.5) # Holocene#
}#
#
minY = 0; maxY = 5000#
add_geochrono(0, -0.05*(maxY-minY))
