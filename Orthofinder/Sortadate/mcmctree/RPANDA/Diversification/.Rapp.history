Dendrobatidae <-read.tree("Dendrobatidae.tre")#
Hemiphractidae <-read.tree("Hemiphractidae.tre")#
Leptodactylidae <-read.tree("Leptodactylidae.tre")#
Liolaemidae <-read.tree("Liolaemidae.tre")#
#
phylo <- list(Aromobatidae, Centrolenidae, Dendrobatidae, Hemiphractidae, Leptodactylidae, Liolaemidae)#
names <- list("Aromobatidae", "Centrolenidae", "Dendrobatidae", "Hemiphractidae", "Leptodactylidae", "Liolaemidae")#
missing.lineages = c(9,32,61,32,37,63)#
#
finalDDD<-list()#
resDDD<-c()
i=1
tree<-phylo[[i]]#
	branch.times<-getx(tree)#
	total.diversity<-Ntip(tree)+missing.lineages[i]#
	resi<-10*(Ntip(tree)+missing.lineages[i])#
cat(i, "tree out of ",length(phylo),": This is the clade",names[[i]],"that originated", round(total.time,2), "Myrs ago", "and includes", total.diversity, "extant species", "\n")
tree<-phylo[[i]]#
	branch.times<-getx(tree)#
	total.time <- max(node.age(tree)$ages)#
	total.diversity<-Ntip(tree)+missing.lineages[i]#
	resi<-10*(Ntip(tree)+missing.lineages[i])#
cat(i, "tree out of ",length(phylo),": This is the clade",names[[i]],"that originated", round(total.time,2), "Myrs ago", "and includes", total.diversity, "extant species", "\n")
library(DDD)#
library(TreePar)#
library(picante)#
#
Aromobatidae <-read.tree("Aromobatidae.tre")#
Centrolenidae <-read.tree("Centrolenidae.tre")#
Dendrobatidae <-read.tree("Dendrobatidae.tre")#
Hemiphractidae <-read.tree("Hemiphractidae.tre")#
Leptodactylidae <-read.tree("Leptodactylidae.tre")#
Liolaemidae <-read.tree("Liolaemidae.tre")#
#
phylo <- list(Aromobatidae, Centrolenidae, Dendrobatidae, Hemiphractidae, Leptodactylidae, Liolaemidae)#
names <- list("Aromobatidae", "Centrolenidae", "Dendrobatidae", "Hemiphractidae", "Leptodactylidae", "Liolaemidae")#
missing.lineages = c(9,32,61,32,37,63)#
#
finalDDD<-list()#
resDDD<-c()
tree<-phylo[[i]]#
	branch.times<-getx(tree)#
	total.time <- max(node.age(tree)$ages)#
	total.diversity<-Ntip(tree)+missing.lineages[i]#
	resi<-10*(Ntip(tree)+missing.lineages[i])#
cat(i, "tree out of ",length(phylo),": This is the clade",names[[i]],"that originated", round(total.time,2), "Myrs ago", "and includes", total.diversity, "extant species", "\n")
cat("BD: Constant birth-death")#
cst_BD<-bd_ML(branch.times, initparsopt = c(0.2,0.01), missnumspec=missing.lineages, tdmodel=0, cond=1, btorph=1, soc=2, maxiter=50000)#
cat(cst_BD)
cat("DDL: Linear dependence of speciation rate without extinction")#
DDD_1<-dd_ML(branch.times, ddmodel=1, initparsopt=c(0.3,total.diversity), idparsopt=c(1,3), idparsfix=c(2), parsfix=c(0), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)#
cat(DDD_1)
cat("DDL+E: Linear dependence of speciation rate with extinction")#
DDD_2<-dd_ML(branch.times, ddmodel=1, initparsopt=c(0.3,0.1,total.diversity), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)#
print(DDD_2)#
cat("DDX+E: Exponential dependence of speciation rate with extinction")#
DDD_3<-dd_ML(branch.times, ddmodel=2, initparsopt=c(0.3,0.1,total.diversity), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)#
print(DDD_3)#
# cat("DD+EL: Linear dependence of extinction rate")#
# DDD_4<-dd_ML(branch.times, ddmodel=3, initparsopt=c(0.2,0.01,total.diversity), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)#
# print(DDD_4)#
cat("DD+EX: Exponential dependence of extinction rate")#
DDD_5<-dd_ML(branch.times, ddmodel=4, initparsopt=c(0.2,0.1,total.diversity), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)#
print(DDD_5)#
# cat("Linear dependence of speciation and extinction rates")#
# DDD_6<-dd_ML(branch.times, ddmodel=5, initparsopt=c(0.2,0.01,total.diversity,0.001), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)#
# print(DDD_6)
DDD_2<-dd_ML(branch.times, ddmodel=1, initparsopt=c(0.3,0.1,total.diversity), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)
DDD_2<-dd_ML(branch.times, ddmodel=1, initparsopt=c(0.2,0.05,total.diversity), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)
DDD_2<-dd_ML(branch.times, ddmodel=1, initparsopt=c(0.2,0.05,total.diversity), idparsopt=c(1,2,3), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)
cst_BD<-bd_ML(branch.times, initparsopt = c(0.2,0.01), missnumspec=missing.lineages, tdmodel=0, cond=1, btorph=1, soc=2, maxiter=50000)
DDD_1<-dd_ML(branch.times, ddmodel=1, initparsopt=c(0.3,total.diversity), idparsopt=c(1,3), idparsfix=c(2), parsfix=c(0), res=resi, missnumspec=missing.lineages, cond=1, btorph=1, soc=2, maxiter=50000)
