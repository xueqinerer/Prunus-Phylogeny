#
axis(side=1, seq(-90, 0, by=10), col="black",col.axis="black",las=1)#
axis(side=4, seq(0, 4500, by=500), col="red",col.axis="red",las=2)#
mtext("Andean elevation (m)",side=4,col="red",line=4)#
#
points(-Andes[,"Age"], Andes[,"Altitude"], pch=17, lwd=0.5, col=alpha(colors[1], 0.3))#
temp.spl<-smooth.spline(-Andes[,"Age"], Andes[,"Altitude"], df=80)#
lines(temp.spl, col=alpha(colors[2], 0.7), lwd=5)#
