# Environment-dependent diversification#
Andes_subset<-subset(Andes, Age<age)#
Andes_spline<-sm.spline(Andes_subset[,"Age"], Andes_subset[,"Altitude"])#
Andes_time<-function(x){predict(Andes_spline,x)}#
#
